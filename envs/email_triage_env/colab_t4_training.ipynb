   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!git clone https://github.com/Rhushya/OpenEnv.git\n",
    "%cd OpenEnv\n",
    "!pip install -U pip\n",
    "!pip install \"torch>=2.3\" \"transformers>=4.46\" \"trl>=0.11.0\" \"accelerate>=0.34\" datasets huggingface_hub bitsandbytes"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
